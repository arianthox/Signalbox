{
  "name": "signalbox",
  "version": "0.1.0",
  "private": true,
  "description": "Local macOS inbox cleanup and important-alert detection app.",
  "main": "dist-electron/main/app.js",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "rebuild:native": "mkdir -p .signalbox-home && HOME=$PWD/.signalbox-home npx electron-rebuild -f -w keytar --arch=arm64",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.2",
    "electron": "^39.2.7",
    "googleapis": "^173.0.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.0",
    "@typescript-eslint/parser": "^8.50.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.15",
    "wait-on": "^9.0.3"
  }
}
